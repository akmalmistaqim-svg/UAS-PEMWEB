{
    "functions": {
        "frontend/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/frontend/(.*).php",
            "dest": "/frontend/$1.php"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}